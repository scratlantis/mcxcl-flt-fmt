{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MCXCL: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "src",
        "-B",
        "build",
        "-DBUILD_MEX=OFF"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MCXCL: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--parallel",
        "4"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "MCXCL: configure"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "MCX: list devices",
      "type": "shell",
      "command": "${workspaceFolder}/bin/mcxcl",
      "args": [
        "-L"
      ],
      "options": {
        "env": {
          "TMPDIR": "/tmp/pocl-temp",
          "POCL_CACHE_DIR": "/tmp/pocl-cache"
        }
      },
      "problemMatcher": []
    },
    {
